generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data/generationali.db"
}

model Document {
  id               String   @id
  tenantId         String
  userId           String
  storageUrl       String
  storageKey       String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Summary {
  id           String   @id
  tenantId     String
  documentId   String
  title        String
  shortSummary String
  fullSummary  String
  createdAt    DateTime @default(now())
  createdBy    String
}
